# Google Gemini API key — get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string
# Local: postgresql://YOUR_MAC_USERNAME@localhost:5432/ragdb
# Supabase: postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://your_mac_username@localhost:5432/ragdb

# (Deployment only) Comma-separated frontend origins for CORS
# CORS_ORIGINS=https://your-app.vercel.app
