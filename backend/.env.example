# Google Gemini API key — get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string
# With Homebrew PostgreSQL, use your Mac username (run `whoami` to find it)
# Format: postgresql://USERNAME@localhost:5432/ragdb
DATABASE_URL=postgresql://your_mac_username@localhost:5432/ragdb
